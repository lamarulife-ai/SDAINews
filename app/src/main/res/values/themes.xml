<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for the activity. The actual colour palette is owned
         by the Compose theme (ui/theme/Theme.kt) which subscribes to the
         user's chosen mode from DataStore. -->
    <style name="Theme.SDAINews" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
