# Copy this file to `keystore.properties` (gitignored) and fill in the
# values from your upload keystore. The release build of the app reads
# this file at build time via `app/build.gradle.kts`.
#
# Generate the keystore once with:
#   keytool -genkeypair -v \
#       -keystore "<absolute-path-to-keystore>" \
#       -alias sdai-upload \
#       -keyalg RSA -keysize 2048 -validity 10000
#
# KEEP THE KEYSTORE FILE AND THESE CREDENTIALS SAFE — if you lose them
# you cannot publish updates to the same Play Store listing.

# Absolute path to the upload keystore (.keystore or .jks).
# Forward slashes work on Windows too; backslashes need escaping.
storeFile=C:/Users/HP/.android/sdai-news-upload.keystore

# Keystore password set during `keytool -genkeypair`.
storePassword=YOUR_KEYSTORE_PASSWORD

# Alias used in the `-alias` flag above.
keyAlias=sdai-upload

# Key password (commonly the same as storePassword).
keyPassword=YOUR_KEY_PASSWORD
